# Supabase
SUPABASE_URL=https://xvzpliyasdrhwjtpzbev.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_Uqz8T3WXasWx8Qo6eql-8g_OhQHEBfs
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PLATFORM_FEE=0.10

# Twilio (OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=concord-xpress
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@concord-xpress.iam.gserviceaccount.com

# HERE Traffic API
HERE_API_KEY=your_here_api_key

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Checkr (Background Checks)
CHECKR_API_KEY=your_checkr_api_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@concordxpress.com

# App
NODE_ENV=development
PORT=3000
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars
FRONTEND_URL=http://localhost:8081

# Concord Xpress
BOOKING_FEE=3.00
PLATFORM_FEE_PCT=0.10
MAX_WAIT_MINS=10
ESCROW_AUTO_RELEASE_HOURS=24
RATING_WINDOW_HOURS=48
